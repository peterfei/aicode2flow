{
  "name": "github-dark",
  "meta": {
    "description": "匹配GitHub Dark的配色方案",
    "author": "aicode2flow",
    "version": "1.0.0"
  },
  "styles": {
    "function": "fill:#569cd6,stroke:#4a8acb,stroke-width:2px,color:#fff",
    "method": "fill:#4ec9b0,stroke:#42b09a,stroke-width:2px,color:#1e1e1e",
    "condition": "fill:#dcdcaa,stroke:#c4c295,stroke-width:2px,color:#1e1e1e",
    "loop": "fill:#ce9178,stroke:#b87e69,stroke-width:2px,color:#1e1e1e",
    "entry": "fill:#c586c0,stroke:#a969a3,stroke-width:4px,color:#fff",
    "class": "fill:#4fc1ff,stroke:#42a8e0,stroke-width:2px,color:#1e1e1e"
  },
  "links": {
    "default": "stroke:#808080,stroke-width:2px,color:#d4d4d4"
  },
  "directives": [
    "init: {'theme':'dark', 'themeVariables': { 'primaryColor': '#569cd6', 'primaryTextColor': '#fff', 'primaryBorderColor': '#4a8acb', 'lineColor': '#808080', 'secondaryColor': '#4ec9b0', 'tertiaryColor': '#dcdcaa', 'background': '#1e1e1e', 'fontSize': '14px' }}"
  ]
}
